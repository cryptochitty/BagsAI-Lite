# ─── App ─────────────────────────────────────────────────────────────────────
APP_NAME=BagsAI Lite
DEBUG=false

# ─── Bags API ─────────────────────────────────────────────────────────────────
# Real API: https://public-api-v2.bags.fm/api/v1
# Get your key at: https://dev.bags.fm → API Keys → Generate new Key
BAGS_API_BASE_URL=https://public-api-v2.bags.fm/api/v1
BAGS_API_KEY=your_bags_api_key_here
BAGS_API_TIMEOUT=10
BAGS_API_RETRIES=3

# ─── Known Token Mints (optional) ────────────────────────────────────────────
# Comma-separated Solana mint addresses of tokens you want to track.
# Used when BITQUERY_API_KEY is not set but BAGS_API_KEY is.
# Example: BAGS_TOKEN_MINTS=mint1base58...,mint2base58...
BAGS_TOKEN_MINTS=

# ─── Bitquery (for trending + volume + holder data) ──────────────────────────
# The official Bags API has no trending endpoint.
# Bitquery indexes all Bags.fm DEX trades in real-time.
# Get a free key at: https://bitquery.io → Sign Up → EAP Access
BITQUERY_API_KEY=your_bitquery_key_here

# ─── OpenAI (optional — enables LLM explanations and chat) ───────────────────
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o-mini

# ─── Redis (optional — falls back to in-memory cache) ────────────────────────
REDIS_URL=redis://localhost:6379/0
CACHE_TTL=300

# ─── Scoring Weights (must sum to 1.0) ───────────────────────────────────────
VOLUME_WEIGHT=0.4
HOLDER_WEIGHT=0.3
ENGAGEMENT_WEIGHT=0.3

# ─── Simulation ───────────────────────────────────────────────────────────────
SIMULATION_INITIAL_CAPITAL=10000.0
SIMULATION_DAYS=30
